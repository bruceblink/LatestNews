{
    "name": "latestnews",
    "type": "module",
    "version": "0.3.0",
    "private": true,
    "packageManager": "pnpm@10.30.3",
    "author": {
        "name": "likanug",
        "email": "likanug.g@qq.com",
        "url": "https://github.com/bruceblink"
    },
    "repository": "https://github.com/bruceblink/latestnews",
    "homepage": "https://news.likanug.top",
    "scripts": {
        "brand:assets": "node ./scripts/brand-assets.mjs",
        "dev": "pnpm presource && vite dev",
        "build": "pnpm presource && vite build",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "commitlint": "commitlint --edit",
        "presource": "tsx ./scripts/favicon.ts && tsx ./scripts/source.ts",
        "start": "node --env-file .env.server dist/output/server/index.mjs",
        "preview": "cross-env CF_PAGES=1 pnpm build && wrangler pages dev dist/output/public",
        "deploy": "cross-env CF_PAGES=1 pnpm build && wrangler pages deploy dist/output/public",
        "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.app.json",
        "check": "pnpm lint:check && pnpm typecheck && pnpm test",
        "release": "bumpp",
        "prepare": "simple-git-hooks",
        "log": "wrangler pages deployment tail --project-name latestnews",
        "test": "vitest -c vitest.config.ts",
        "caching": "ts-node ./server/database/caching.ts"
    },
    "dependencies": {
        "@atlaskit/pragmatic-drag-and-drop": "^1.5.0",
        "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.0",
        "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.0.3",
        "@formkit/auto-animate": "^0.8.2",
        "@iconify-json/si": "^1.2.3",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@tanstack/react-query": "^5.66.11",
        "@tanstack/react-query-devtools": "^5.66.11",
        "@tanstack/react-router": "^1.112.0",
        "@unocss/reset": "^66.0.0",
        "ahooks": "^3.8.4",
        "better-sqlite3": "^11.10.0",
        "buffer": "^6.0.3",
        "cheerio": "^1.0.0",
        "clsx": "^2.1.1",
        "cmdk": "^1.0.4",
        "consola": "^3.4.0",
        "cookie-es": "^2.0.0",
        "dayjs": "1.11.13",
        "db0": "^0.3.1",
        "defu": "^6.1.4",
        "dotenv": "^17.2.2",
        "dotenv-flow": "^4.1.0",
        "fast-xml-parser": "^5.5.10",
        "framer-motion": "^12.4.7",
        "h3": "^1.15.11",
        "iconv-lite": "^0.6.3",
        "jose": "^6.0.8",
        "jotai": "^2.12.1",
        "jwt-decode": "^4.0.0",
        "md5": "^2.3.0",
        "ofetch": "^1.4.1",
        "overlayscrollbars": "^2.11.1",
        "react": "^18.3.1",
        "react-device-detect": "^2.2.3",
        "react-dom": "^18.3.1",
        "react-use": "^17.6.0",
        "uncrypto": "^0.1.3",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@resvg/resvg-js": "^2.6.2",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint-react/eslint-plugin": "^1.29.0",
        "@eslint/js": "^9.36.0",
        "@iconify-json/ph": "^1.2.2",
        "@napi-rs/pinyin": "^1.7.5",
        "@ourongxing/eslint-config": "3.2.3-beta.6",
        "@ourongxing/tsconfig": "^0.0.4",
        "@rollup/pluginutils": "^5.1.4",
        "@tanstack/router-devtools": "^1.112.0",
        "@tanstack/router-plugin": "^1.112.0",
        "@types/node": "22.15.32",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.1",
        "@typescript-eslint/eslint-plugin": "^8.44.0",
        "@typescript-eslint/parser": "^8.44.0",
        "@unocss/rule-utils": "^66.0.0",
        "@vitejs/plugin-react-swc": "^3.8.0",
        "bumpp": "^10.0.3",
        "cross-env": "^7.0.3",
        "eslint": "^9.21.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-import-x": "^4.16.1",
        "eslint-plugin-perfectionist": "^4.15.0",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "eslint-plugin-unused-imports": "^4.2.0",
        "fast-glob": "^3.3.3",
        "favicons-scraper": "^1.3.2",
        "globals": "^16.4.0",
        "lint-staged": "^15.4.3",
        "pnpm-patch-i": "^0.4.1",
        "prettier": "^3.6.2",
        "rollup": "^4.59.0",
        "simple-git-hooks": "^2.11.1",
        "ts-node": "10.9.2",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.25.0",
        "unimport": "^4.1.2",
        "unocss": "^66.0.0",
        "vite": "7.3.1",
        "vite-plugin-pwa": "^0.21.1",
        "vite-plugin-with-nitro": "0.0.5",
        "vitest": "^3.0.7",
        "workbox-build": "^7.3.0",
        "workbox-window": "^7.3.0",
        "wrangler": "^4.59.1"
    },
    "pnpm": {
        "patchedDependencies": {
            "dayjs": "patches/dayjs.patch"
        },
        "overrides": {
            "h3": "1.15.5",
            "unenv": "1.10.0",
            "cross-spawn": ">=7.0.6",
            "picomatch": "^4.0.2"
        },
        "onlyBuiltDependencies": [
            "@napi-rs/pinyin",
            "@parcel/watcher",
            "@swc/core",
            "esbuild",
            "better-sqlite3",
            "sharp",
            "simple-git-hooks",
            "unrs-resolver",
            "workerd"
        ]
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "pnpm exec commitlint --edit $1"
    },
    "lint-staged": {
        "*.{js,mjs,cjs,ts,tsx}": "eslint --fix"
    }
}
